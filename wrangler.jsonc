{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "zxll-website",
  // Cloudflare Workers 兼容日期：按当前部署日期固定，避免未来平台默认行为变化
  "compatibility_date": "2026-05-09",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    // Astro 构建产物目录；wrangler deploy 会把这里的静态资源上传到 Workers
    "directory": "./dist",
    // 静态站点：未知路径返回 dist/404.html
    "not_found_handling": "404-page"
  }
}
