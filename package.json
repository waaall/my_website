{
  "name": "my-website",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,css,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.2",
    "astro": "^5.15.0",
    "dayjs": "^1.11.19",
    "github-slugger": "^2.0.0",
    "katex": "^0.16.27",
    "pagefind": "^1.4.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.55.1",
    "@types/node": "^25.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
