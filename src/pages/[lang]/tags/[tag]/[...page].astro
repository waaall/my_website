---
import type { GetStaticPaths } from 'astro';
import type { Lang, Post } from '@/types/post';
import { siteConfig } from '@/config/site';
import { messages } from '@/i18n/locales';
import { routePaths } from '@/lib/routes';
import { getPostsByLang, getTagCounts } from '@/lib/posts';
import { slugifyTag } from '@/lib/post-helpers';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';

// 双语 × 每个标签 × 分页：用 slug 作为 URL，原始标签塞 props
export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const all = await Promise.all(
    siteConfig.supportedLangs.map(async (lang) => {
      const tagCounts = await getTagCounts(lang);
      const posts = await getPostsByLang(lang);
      const perTag = await Promise.all(
        Array.from(tagCounts.keys()).map((tag) => {
          const slug = slugifyTag(tag);
          const matched = posts.filter((p) => p.tags.includes(tag));
          return paginate(matched, {
            params: { lang, tag: slug },
            props: { tag },
            pageSize: siteConfig.postsPerPage,
          });
        }),
      );
      return perTag.flat();
    }),
  );
  return all.flat();
};

type Props = {
  page: import('astro').Page<Post>;
  tag: string; // 原始标签字符串（含中文）
};

const { page, tag } = Astro.props as Props;
const lang = Astro.params.lang as Lang;
const t = messages[lang];
---

<BaseLayout lang={lang} title={`#${tag} · ${siteConfig.name[lang]}`}>
  <section class="container container--content tag-page">
    <PageHeader
      title={`#${tag}`}
      subtitle={`${t.archive.total(page.total)} · ${t.common.pageOf(page.currentPage, page.lastPage)}`}
    />

    {page.data.map((post) => <PostCard post={post} lang={lang} showTags={false} />)}

    <Pagination
      lang={lang}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
    />

    <p class="tag-page__back">
      <a href={routePaths.tags(lang)}>← {t.common.allTags}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding-bottom: var(--sp-10);
  }

  .tag-page__back {
    margin-top: var(--sp-6);
    font-size: var(--fs-sm);
  }
</style>
